# Heart of Virtue — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# -------------------------------------------------------
# Flask
# -------------------------------------------------------
# Required in production. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-generate-with-secrets-token-hex

FLASK_ENV=development
FLASK_DEBUG=true

# -------------------------------------------------------
# Database (Turso / LibSQL)
# -------------------------------------------------------
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# -------------------------------------------------------
# AI integration (Mynx NPC ambient behavior)
# Set MYNX_LLM_ENABLED=0 to disable entirely — no API key needed.
# -------------------------------------------------------
MYNX_LLM_ENABLED=0
MYNX_LLM_PROVIDER=openrouter

# OpenRouter (preferred)
OPENROUTER_API_KEY=

# Anthropic direct
ANTHROPIC_API_KEY=

# OpenAI direct
OPENAI_API_KEY=

# -------------------------------------------------------
# GitHub Feedback Integration
# Personal Access Token with issues:write scope on azureknight63/heart-of-virtue
# Without this, the in-game Feedback button returns a 503 (game is unaffected).
# -------------------------------------------------------
GITHUB_TOKEN=

# -------------------------------------------------------
# Optional
# -------------------------------------------------------
# Path to a .ini config file for map/starting-position overrides
# CONFIG_FILE=config_dev.ini

# Server port (defaults to 5000)
# PORT=5000
